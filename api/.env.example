# ── Core ──
DATABASE_URL=postgresql+asyncpg://tokenbudget:localdev@localhost:5432/tokenbudget
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-this-to-a-random-secret-key
ENVIRONMENT=development
ADMIN_KEY=change-this-admin-key

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://localhost:3000"]

# ── Auth Mode ──
# "local"  — email + password with JWT (default, no external services needed)
# "clerk"  — Clerk OAuth (Google, magic link) — set keys below
# "none"   — no auth, single-user mode (auto-provisions API key on first visit)
AUTH_MODE=local

# ── Clerk Auth (only needed when AUTH_MODE=clerk) ──
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── Signup Control ──
SIGNUPS_ENABLED=true
SIGNUPS_PAUSED_MESSAGE=We are at capacity. Join the waitlist and we will notify you.

# ── Default Limits (generous — effectively unlimited) ──
FREE_EVENTS_PER_MONTH=10000000
FREE_KEYS_MAX=100
FREE_RETENTION_DAYS=365
FREE_PROJECTS_MAX=100

# ── Purge Job ──
PURGE_ENABLED=true
PURGE_CRON_HOUR=3
PURGE_BATCH_SIZE=5000

# ── Database Pool ──
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
